// Simple test MIL program for ANE compilation validation
// This is a minimal program to verify ANE compilation works

program(1.3)
[buildInfo = dict<string, string>({{"coremlc-component-MIL", "3510.2.1"}})]
{
    func main<ios18>(
        tensor<fp16, [1, 512, 1, 1024]> input
    ) {
        // Simple identity operation to test compilation
        tensor<fp16, [1, 512, 1, 1024]> output = identity(x=input)[name=string("output")];
    } -> (output);
}